  role: { foreground: "#5599e2" }
  typ: { foreground: "#5679e3" }
  range: { foreground: "#956dca" }

file_type:
  image: { foreground: "#3f8cde" }
  video: { foreground: "#56b7c8" }
  music: { foreground: "#5599e2" }
