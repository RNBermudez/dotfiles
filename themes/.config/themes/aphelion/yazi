title = { fg = "#56B7C8" }
hovered = { fg = "#f4f3ee", bg = "#3A435A" }

# Which
[which]
cols = 3
mask = { bg = "#101319" }
cand = { fg = "#5599E2" }
rest = { fg = "#5679E3" }
desc = { fg = "#956dca" }
separator = " Ō×£ "
