list = {}
btn_yes = { bg = "#3A435A" }
btn_no = {}
btn_labels = ["  [Y]es  ", "  (N)o  "]

# Spot
[spot]
border = { fg = "#56B7C8" }
title = { fg = "#56B7C8" }

# Notify
[notify]
title_info = { fg = "#56B7C8" }
title_warn = { fg = "#e37e4f" }
title_error = { fg = "#DE2B2B" }

icon_error = "’üŚ"
icon_warn = "’ü▒"
icon_info = "’üÜ"

# Help
[help]
on = { fg = "#69bfce" }
run = { fg = "#956dca" }
desc = { fg = "#5599E2" }
hovered = { bg = "#3A435A" }
footer = { fg = "#f4f3ee", bg = "#101319" }

[filetype]

rules = [
  # Images
  { mime = "image/*", fg = "#e37e4f" },

  # Media
  { mime = "{audio,video}/*", fg = "#956dca" },

  # Archives
  { mime = "application/*zip", fg = "#E34F4F" },
  { mime = "application/x-{tar,bzip*,7z-compressed,xz,rar}", fg = "#E34F4F" },

  # Documents
  { mime = "application/{pdf,doc,rtf,vnd.*}", fg = "#5599E2" },

  # Special files
  { name = "*", is = "orphan", bg = "#DE2B2B" },
  { name = "*", is = "exec", fg = "#69bfce" },

  # Fallback
  { name = "*/", fg = "#5679E3" },
  { name = "*", fg = "#f4f3ee" },
]
